# Copie para backend/.env e preencha. O .env real NUNCA vai para o git.
#   cp .env.example .env

# ---------------------------------------------------------------- banco
# Driver psycopg v3. O usuário e a base são criados no passo 1 do DEPLOY.md.
DATABASE_URL=postgresql+psycopg://topai_app:TROCAR_SENHA_DO_BANCO@localhost:5432/topai

# ------------------------------------------------------------------ auth
# Gere um segredo forte:  openssl rand -hex 32
# Trocar este valor desloga todo mundo (invalida os tokens emitidos).
JWT_SECRET=TROCAR_gere_com_openssl_rand_hex_32

# Ferramenta interna, token de vida longa.
JWT_EXPIRE_DAYS=30

# ------------------------------------------------------------------ cors
# Origens separadas por vírgula. Em produção, front e API ficam no mesmo
# domínio, então isto quase não é exercitado — mas mantenha correto.
# Para dev com o front em outra porta, acrescente: ,http://localhost:5500
CORS_ORIGINS=https://gestao.topai.com.br

# ------------------------------------------------------------------ seed
# Usados só por `python -m app.seed`.
# As SENHAS SÃO OBRIGATÓRIAS: sem elas o seed aborta e não cria ninguém.
# Defina-as ANTES de rodar o seed. Os emails têm padrão e são opcionais.
SEED_MATHEUS_EMAIL=matheus@topai.com.br
SEED_MATHEUS_PASSWORD=
SEED_GEOVANNY_EMAIL=geovanny@topai.com.br
SEED_GEOVANNY_PASSWORD=

# APENAS desenvolvimento local: libera a senha de exemplo do repositório
# quando as SEED_*_PASSWORD estão vazias. Nunca defina isto no VPS.
# SEED_ALLOW_DEV_PASSWORD=1
